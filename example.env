# Copy this file to .env and adjust values for your local environment.
# Do not commit .env files: they may contain machine-specific paths or future credentials.

# Root directory that future repository tools may inspect. Defaults to the current directory.
AI_CHANGE_AGENT_WORKSPACE_ROOT=.

# Logging threshold: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
AI_CHANGE_AGENT_LOG_LEVEL=INFO

# Maximum number of bytes a future read-file tool may load from one file.
AI_CHANGE_AGENT_MAX_FILE_BYTES=1048576
